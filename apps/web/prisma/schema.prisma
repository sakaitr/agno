// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ───────────────────────────────────────────────────
model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(ADMIN)
  avatar       String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  blogPosts    BlogPost[]

  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

// ─── SERVICES ───────────────────────────────────────────────
model Service {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  shortDesc   String
  description String   @db.Text
  icon        String
  coverImage  String?
  features    Json     @default("[]") // string[]
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  portfolio    Portfolio[]
  contacts     ContactMessage[]

  @@map("services")
}

// ─── PORTFOLIO ──────────────────────────────────────────────
model Portfolio {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  client       String
  description  String   @db.Text
  coverImage   String
  images       Json     @default("[]") // string[]
  technologies Json     @default("[]") // string[]
  year         Int
  isFeatured   Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])

  @@map("portfolio")
}

// ─── BLOG ───────────────────────────────────────────────────
model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  content     String    @db.Text  // MDX content
  coverImage  String?
  tags        Json      @default("[]") // string[]
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@map("blog_posts")
}

// ─── CONTACT ────────────────────────────────────────────────
model ContactMessage {
  id        String        @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  company   String?
  subject   String
  message   String        @db.Text
  status    ContactStatus @default(NEW)
  isRead    Boolean       @default(false)
  notes     String?       @db.Text  // internal notes
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])

  @@map("contact_messages")
}

enum ContactStatus {
  NEW
  IN_PROGRESS
  REPLIED
  CLOSED
}

// ─── AGNO DESIGN - PRODUCTS ─────────────────────────────────
model DesignProduct {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  description     String   @db.Text
  price           Decimal  @db.Decimal(10, 2)
  images          Json     @default("[]") // string[]
  category        String
  material        String
  dimensions      String?  // örn: "10x10x5 cm"
  weight          String?  // örn: "50g"
  colors          Json     @default("[]") // available colors
  isCustomizable  Boolean  @default(false)
  stock           Int      @default(0)
  isActive        Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("design_products")
}

// ─── TESTIMONIALS ───────────────────────────────────────────
model Testimonial {
  id          String   @id @default(cuid())
  authorName  String
  authorTitle String
  company     String
  content     String   @db.Text
  rating      Int      @default(5) // 1-5
  avatar      String?  // initials or image URL
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  @@map("testimonials")
}

// ─── TEAM MEMBERS ───────────────────────────────────────────
model TeamMember {
  id        String   @id @default(cuid())
  name      String
  title     String
  bio       String   @db.Text
  photo     String?
  linkedin  String?
  twitter   String?
  skills    Json     @default("[]") // string[]
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("team_members")
}

// ─── SITE SETTINGS ──────────────────────────────────────────
model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  group     String   @default("general")
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}
