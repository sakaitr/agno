# ============================================
# AGNO — Ortam Degiskenleri
# Bu dosyayi .env olarak kopyalayin ve doldurun
# cp .env.example .env
# ============================================

# Veritabani (Supabase PostgreSQL)
DATABASE_URL=mysql://cpanel_kullanici:sifre@localhost:3306/cpanel_veritabani

# NextAuth
NEXTAUTH_URL=https://agno.com.tr
NEXTAUTH_SECRET=en-az-32-karakter-gizli-anahtar-buraya

# Admin hesabi
ADMIN_EMAIL=admin@agno.com.tr
ADMIN_PASSWORD_HASH=

# E-posta (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@agno.com.tr

# Gorsel CDN (Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Site
NEXT_PUBLIC_SITE_URL=https://agno.com.tr
NEXT_PUBLIC_WHATSAPP_NUMBER=905000000000
NEXT_PUBLIC_GA_ID=